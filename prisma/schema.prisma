// Prisma Schema for HRIS Philippines - MongoDB
// This schema defines the database models for a Human Resource Information System
// compliant with Philippine labor laws and payroll calculations.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

// ============================================================================
// MODELS
// ============================================================================

/// User model for authentication
/// Links to Employee record for role-based access
model User {
  id            String    @id @default(auto()) @map("_id") @db.ObjectId
  username      String    @unique
  email         String    @unique
  name          String?
  password      String?
  role          String    @default("EMPLOYEE")
  status        String    @default("FOR_APPROVAL")
  image         String?
  emailVerified DateTime?

  failedAttempts Int      @default(0)
  lockUntil      DateTime?

  employees      Employee[]

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@map("users")
}

/// Employee model containing HR-related information
model Employee {
  id            String    @id @default(auto()) @map("_id") @db.ObjectId

  userId        String?   @db.ObjectId
  user          User?     @relation(fields: [userId], references: [id], onDelete: Cascade)

  employeeNumber Int?     @unique
  fullName      String
  email         String    @unique

  employeeId    String    @unique
  position      String
  department    String

  basicSalary   Float
  payrollFrequency String @default("MONTHLY")

  hireDate      DateTime
  endDate       DateTime?
  isActive      Boolean   @default(true)

  tin           String
  sssNo         String
  philhealthNo  String
  pagibigNo     String

  bankName      String?
  bankAccountNo String?

  managerId     String?   @db.ObjectId
  manager       Employee? @relation("ReportingLine", fields: [managerId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  subordinates  Employee[] @relation("ReportingLine")

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  timeLogs      TimeLog[]
  payrolls      Payroll[]
  leaveRequests LeaveRequest[] @relation("EmployeeLeaves")
  approvedLeaves LeaveRequest[] @relation("ApproverLeaves")
  overtimeRequests OvertimeRequest[] @relation("EmployeeOvertime")
  approvedOvertime OvertimeRequest[] @relation("ApproverOvertime")

  @@map("employees")
}

/// Leave request status enum
enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

/// Overtime status enum
enum OtStatus {
  PENDING
  APPROVED
  REJECTED
}

/// LeaveRequest model for filing and approving leaves
model LeaveRequest {
  id           String      @id @default(auto()) @map("_id") @db.ObjectId

  employeeId   String      @db.ObjectId
  employee     Employee    @relation("EmployeeLeaves", fields: [employeeId], references: [id], onDelete: Cascade)
  
  approverId   String?     @db.ObjectId
  approver     Employee?   @relation("ApproverLeaves", fields: [approverId], references: [id])
  
  leaveType    String      // e.g., VACATION, SICK, EMERGENCY, MATERNITY, PATERNITY
  startDate    DateTime
  endDate      DateTime
  daysCount    Float
  reason       String
  status       LeaveStatus @default(PENDING)
  
  adminNotes   String?     // Notes from the approver
  
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  @@map("leaverequests")
}

/// OvertimeRequest model for filing and approving overtime
model OvertimeRequest {
  id           String      @id @default(auto()) @map("_id") @db.ObjectId

  employeeId   String      @db.ObjectId
  employee     Employee    @relation("EmployeeOvertime", fields: [employeeId], references: [id], onDelete: Cascade)
  
  approverId   String?     @db.ObjectId
  approver     Employee?   @relation("ApproverOvertime", fields: [approverId], references: [id])
  
  date         DateTime
  hours        Float
  reason       String
  status       OtStatus    @default(PENDING)
  
  adminNotes   String?     // Notes from the approver
  
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  @@map("overtimerequests")
}

/// TimeLog model for daily attendance tracking
model TimeLog {
  id          String    @id @default(auto()) @map("_id") @db.ObjectId

  employeeId  String    @db.ObjectId
  employee    Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  date        DateTime
  clockIn     DateTime?
  clockOut    DateTime?

  workHours   Float     @default(0)
  otHours     Float     @default(0)
  otStatus    OtStatus  @default(PENDING)
  lateMinutes Float     @default(0)
  undertimeMinutes Float @default(0)

  notes       String?

  isEdited    Boolean   @default(false)
  editedBy    String?
  editReason  String?

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([employeeId, date])
  @@map("timelogs")
}

/// Payroll model for monthly payroll records
model Payroll {
  id          String    @id @default(auto()) @map("_id") @db.ObjectId

  employeeId  String    @db.ObjectId
  employee    Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  month       Int
  year        Int
  periodStart DateTime
  periodEnd   DateTime

  basicSalary     Float
  workDays        Float
  daysWorked      Float

  otHours         Float     @default(0)
  otPay           Float     @default(0)

  grossPay        Float     @default(0)

  sssEmployee     Float     @default(0)
  sssEmployer     Float     @default(0)
  philhealthEmployee Float  @default(0)
  philhealthEmployer Float  @default(0)
  pagibigEmployee Float     @default(0)
  pagibigEmployer Float     @default(0)

  withholdingTax Float     @default(0)

  otherDeductions Float     @default(0)

  totalDeductions Float    @default(0)
  netPay          Float    @default(0)

  status          String    @default("DRAFT")

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  processedAt     DateTime?
  approvedBy      String?
  approvedAt      DateTime?

  @@unique([employeeId, periodStart, periodEnd])
  @@index([employeeId, month, year])
  @@map("payrolls")
}
